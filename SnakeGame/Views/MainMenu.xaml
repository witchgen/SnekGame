<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:SnakeGame.ViewModels"
             x:Class="SnakeGame.Views.MainMenu"
             x:DataType="local:MainMenuViewModel"
             Shell.NavBarIsVisible="False">
    <VerticalStackLayout>
        <Grid
            HorizontalOptions="Center"
            VerticalOptions="Fill"
            RowDefinitions="*, *">
            <VerticalStackLayout
                    Grid.Row="0"
                    Margin="20"
                    Spacing="33"
                    HorizontalOptions="Center">
                <Label
                    Text="🐍"
                    FontSize="72"
                    HorizontalOptions="Center">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding AppointDebugOptionsCommand}" />
                    </Label.GestureRecognizers>
                </Label>
                <Label 
                    Text="{Binding Greeting}"
                    FontSize="30"
                    HorizontalTextAlignment="Center"
                    TextColor="LightGreen"
                    LineBreakMode="WordWrap"
                    HorizontalOptions="Center"/>
                <Button 
                    Text="К игре! 🎮"
                    BackgroundColor="#80ed99"
                    Command="{Binding GoToLegacyGameCommand}"
                    HorizontalOptions="Fill"
                    VerticalOptions="Center"
                    FontSize="22"/>
                <Button
                    x:Name="LeaderboardBtn"
                    BackgroundColor="#57cc99"
                    Command="{Binding GoToRecordsCommand}"
                    FontSize="22"
                    HorizontalOptions="Fill"
                    VerticalOptions="Center"
                    Text="К рекордам 🏆"></Button>
                <Button 
                    Text="Настройки 🛠️"
                    BackgroundColor="#38a3a5"
                    Command="{Binding GoToOptionsCommand}"
                    HorizontalOptions="Fill"
                    VerticalOptions="Center"
                    FontSize="22"/>
            </VerticalStackLayout>
            <!--<BoxView Grid.Row="1" HeightRequest="100" BackgroundColor="Transparent" VerticalOptions="Fill" />-->
            <VerticalStackLayout
                Grid.Row="1"
                Margin="20"
                Padding="50, 100, 50, 20">
                <Button
                    x:Name="UpdateBtn"
                    BackgroundColor="#22577a"
                    Command="{Binding GoGetUpdateCommand}"
                    IsVisible="{Binding IsThereUpdate}"
                    VerticalOptions="End"
                    HorizontalOptions="Fill"
                    FontSize="20"
                    LineBreakMode="WordWrap"
                    TextColor="AliceBlue"
                    Text="Доступно новое обновление! Жми сюда, чтобы скачать!"></Button>
                <Label 
                    TextColor="#888"
                    FontSize="22"
                    HorizontalTextAlignment="Center"
                    Text="{Binding CurrentVersion,
                            StringFormat='v{0}'}"/>
            </VerticalStackLayout>
        </Grid>
    </VerticalStackLayout>
</ContentPage>