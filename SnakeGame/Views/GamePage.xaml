<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:skia="clr-namespace:SkiaSharp.Views.Maui.Controls;assembly=SkiaSharp.Views.Maui.Controls"
             xmlns:local="clr-namespace:SnakeGame.ViewModels"
             x:Class="SnakeGame.Views.GamePage"
             x:DataType="local:GameViewModel">

    <Grid RowDefinitions="*,*" RowSpacing="15">

        <!-- Игровое поле -->
        <!-- Видно всегда, кроме фазы настройки -->
        <skia:SKCanvasView Grid.Row="0"
            x:Name="gameScreen"
            PaintSurface="OnGameScreenPaintSurface"
            IsVisible="True"
            VerticalOptions="Fill"
            HorizontalOptions="Fill"
            Background="Transparent"
            EnableTouchEvents="False">
        </skia:SKCanvasView>

        <!-- Тачскрин для управления жестами -->
        <!-- Видно только во время игры -->
        <Border 
            IsVisible="{Binding IsPlaying}"
            Grid.Row="1"
            Margin="25"
            Stroke="DarkSlateBlue"
            StrokeThickness="3"
            StrokeShape="RoundRectangle 20">
            <skia:SKCanvasView
                x:Name="TouchPanel"
                Touch="OnTouchPanelTouch"
                PaintSurface="OnTouchPanelPaint"
                BackgroundColor="Transparent"
                EnableTouchEvents="True"
                HorizontalOptions="Fill"
                VerticalOptions="Fill"/>
        </Border>

        <!-- Панель настроек -->
        <!-- Видно при инициализации или геймовере -->
        <VerticalStackLayout Spacing="8" Margin="10" Grid.Row="1" IsVisible="{Binding IsSetupVisible}">

            <!-- GameOver: кнопка возврата к настройкам -->
            <Button Text="← К настройкам"
                    IsVisible="{Binding ShowGameOver}"
                    Command="{Binding ShowSetupCommand}"
                    BackgroundColor="Green"/>
            <!-- Setup: генерация поля -->
            <Button Text="Сгенерировать поле"
                    IsVisible="{Binding CanGenerateField}"
                    IsEnabled="{Binding SettingsAreValid}"
                    Command="{Binding GenerateFieldCommand}" />
            <!-- Ready: старт игры -->
            <Button Text="Стартуем!"
                    BackgroundColor="OrangeRed"
                    Command="{Binding StartGameCommand}"
                    IsVisible="{Binding CanStartGame}"/>

            <!-- Настройки — только в Setup -->
            <Grid
                RowDefinitions="Auto, Auto, Auto"
                ColumnDefinitions="*, *, *, *"
                IsVisible="{Binding CanGenerateField}">
                <Label
                    Grid.Row="0" Grid.Column="0"
                    VerticalTextAlignment="Center"
                    HorizontalTextAlignment="End"
                    Text="Высота:"/>
                <Entry Grid.Row="0" Grid.Column="1"
                    Placeholder="Rows"
                    Keyboard="Numeric"
                    Text="{Binding Settings.Rows}" />
                <Label
                    Grid.Row="0" Grid.Column="2"
                    VerticalTextAlignment="Center"
                    HorizontalTextAlignment="End"
                    Text="Ширина:"/>
                <Entry Grid.Row="0" Grid.Column="3"
                    Placeholder="Cols"
                    Keyboard="Numeric"
                    Text="{Binding Settings.Cols}" />

                <Label
                    Grid.Row="1" Grid.Column="0"
                    VerticalTextAlignment="Center"
                    HorizontalTextAlignment="End"
                    Text="Клетка спавна (высота):"/>
                <Entry Grid.Row="1" Grid.Column="1"
                    Placeholder="Snake spawn i"
                    Keyboard="Numeric"
                    Text="{Binding Settings.SnakeSpawnPointI}" />
                <Label
                    Grid.Row="1" Grid.Column="2"
                    VerticalTextAlignment="Center"
                    HorizontalTextAlignment="End"
                    Text="Клетка спавна (ширина):"/>
                <Entry Grid.Row="1" Grid.Column="3"
                    Placeholder="Snake spawn j"
                    Keyboard="Numeric"
                    Text="{Binding Settings.SnakeSpawnPointJ}" />

                <Label
                    Grid.Row="2" Grid.Column="0"
                    VerticalTextAlignment="Center"
                    HorizontalTextAlignment="End"
                    Text="Кол-во бомб:"/>
                <Entry Grid.Row="2" Grid.Column="1"
                    Placeholder="Bombs count"
                    Keyboard="Numeric"
                    Text="{Binding Settings.BombsCount}" />

                <Label
                    Grid.Row="2" Grid.Column="2"
                    VerticalTextAlignment="Center"
                    HorizontalTextAlignment="End"
                    Text="Зерно:"/>
                <Entry Grid.Row="2" Grid.Column="3"
                    Placeholder="Seed (optional)"
                    Keyboard="Numeric"
                    Text="{Binding Settings.Seed}" />
            </Grid>

        </VerticalStackLayout>

    </Grid>
</ContentPage>