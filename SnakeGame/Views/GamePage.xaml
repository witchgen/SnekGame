<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="SnakeGame.Views.GamePage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:behavior="clr-namespace:SnakeGame.ViewModels.Behaviors"
    xmlns:local="clr-namespace:SnakeGame.ViewModels"
    xmlns:skia="clr-namespace:SkiaSharp.Views.Maui.Controls;assembly=SkiaSharp.Views.Maui.Controls"
    x:DataType="local:GameViewModel">

    <!--  AbsoluteLayout —> overlay-панель поверх всего  -->
    <AbsoluteLayout>

        <!--
            ═══════════════════════════════════════
            ОСНОВНОЙ GRID (игра + кнопки + тачпад)
            ═══════════════════════════════════════
        -->
        <Grid
            AbsoluteLayout.LayoutBounds="0,0,1,1"
            AbsoluteLayout.LayoutFlags="All"
            RowDefinitions="Auto, 3*, 2*, Auto"
            RowSpacing="0">

            <!--  ROW 0: Счетчик очков + верхнее меню  -->
            <Grid
                Grid.Row="0"
                BackgroundColor="Transparent"
                ColumnDefinitions="*, *, *"
                ColumnSpacing="8">
                <Label
                    Grid.Column="1"
                    IsVisible="{Binding ShowScore}"
                    FontSize="22"
                    HorizontalOptions="Center"
                    Text="{Binding GameScore}">
                    <Label.Behaviors>
                        <behavior:ScorePulseBehavior />
                    </Label.Behaviors>
                </Label>
            </Grid>


            <!--  ROW 1: ИГРОВОЕ ПОЛЕ  -->
            <skia:SKCanvasView
                x:Name="gameScreen"
                Grid.Row="1"
                EnableTouchEvents="False"
                HorizontalOptions="Center"
                PaintSurface="OnGameScreenPaintSurface"
                VerticalOptions="Start" />

            <!--  ROW 2: ТАЧПАД (виден только во время игры/паузы)  -->
            <Border
                Grid.Row="2"
                Grid.RowSpan="2"
                Margin="15,5,15,10"
                HorizontalOptions="Fill"
                IsVisible="{Binding IsPlaying}"
                Stroke="#477447"
                StrokeShape="RoundRectangle 20"
                StrokeThickness="3"
                VerticalOptions="Fill">
                <skia:SKCanvasView
                    x:Name="TouchPanel"
                    BackgroundColor="Transparent"
                    EnableTouchEvents="True"
                    PaintSurface="OnTouchPanelPaint"
                    Touch="OnTouchPanelTouch" />
            </Border>

            <!--  ROW 3: ФИКСИРОВАННАЯ ПАНЕЛЬ КНОПОК  -->
            <Grid
                Grid.Row="3"
                Padding="8,5"
                BackgroundColor="#1a2f1a"
                ColumnDefinitions="*, *, *"
                ColumnSpacing="8"
                IsVisible="{Binding CanShowBottomBar}">

                <!--  Перегенерировать  -->
                <Border
                    Grid.Column="0"
                    IsVisible="{Binding CanReroll}"
                    Stroke="#8CBB60"
                    StrokeShape="RoundRectangle 28"
                    StrokeThickness="2">
                    <Border.Shadow>
                        <Shadow
                            Brush="Black"
                            Opacity="0.5"
                            Radius="10"
                            Offset="0,2" />
                    </Border.Shadow>
                    <Border
                        Stroke="#477447"
                        StrokeShape="RoundRectangle 28"
                        StrokeThickness="3">
                        <Button
                            BackgroundColor="#6CB06C"
                            Command="{Binding ResetFieldCommand}"
                            CornerRadius="28"
                            FontSize="18"
                            IsEnabled="{Binding SettingsAreValid}"
                            Text="🎲 Перегенерировать">
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroupList>
                                    <VisualStateGroup x:Name="CommonStates">
                                        <VisualState x:Name="Disabled">
                                            <VisualState.Setters>
                                                <Setter Property="BackgroundColor" Value="#718270" />
                                                <Setter Property="TextColor" Value="DarkRed" />
                                            </VisualState.Setters>
                                        </VisualState>
                                        <VisualState x:Name="Normal">
                                            <VisualState.Setters>
                                                <Setter Property="BackgroundColor" Value="#6CB06C" />
                                                <Setter Property="TextColor" Value="Black" />
                                            </VisualState.Setters>
                                        </VisualState>
                                    </VisualStateGroup>
                                </VisualStateGroupList>
                            </VisualStateManager.VisualStateGroups>
                        </Button>
                    </Border>
                </Border>

                <!--  Стартуем!  -->
                <Border
                    Grid.Column="1"
                    IsVisible="{Binding CanStartGame}"
                    Stroke="#8CBB60"
                    StrokeShape="RoundRectangle 28"
                    StrokeThickness="2">
                    <Border.Shadow>
                        <Shadow
                            Brush="Black"
                            Opacity="0.5"
                            Radius="10"
                            Offset="0,2" />
                    </Border.Shadow>
                    <Border
                        Stroke="#477447"
                        StrokeShape="RoundRectangle 28"
                        StrokeThickness="3">
                        <Button
                            BackgroundColor="#CEE98F"
                            Command="{Binding StartGameCommand}"
                            CornerRadius="28"
                            FontSize="18"
                            Text="▶ Стартуем!" />
                    </Border>
                </Border>

                <!--  К настройкам  -->
                <Border
                    Grid.Column="2"
                    Stroke="#8CBB60"
                    StrokeShape="RoundRectangle 28"
                    StrokeThickness="2">
                    <Border.Shadow>
                        <Shadow
                            Brush="Black"
                            Opacity="0.5"
                            Radius="10"
                            Offset="0,2" />
                    </Border.Shadow>
                    <Border
                        Stroke="#477447"
                        StrokeShape="RoundRectangle 28"
                        StrokeThickness="3">
                        <Button
                            BackgroundColor="#6CB06C"
                            Command="{Binding ShowSetupCommand}"
                            CornerRadius="28"
                            FontSize="18"
                            Text="📝 Опции" />
                    </Border>
                </Border>
            </Grid>

        </Grid>

        <!--
            ═══════════════════════════════════════
            ВСПЛЫВАЮЩАЯ ПАНЕЛЬ НАСТРОЕК (overlay)
            ═══════════════════════════════════════
        -->
        <Border
            x:Name="SetupPanel"
            Padding="15"
            AbsoluteLayout.LayoutBounds="0.5,0.5,0.9,0.8"
            AbsoluteLayout.LayoutFlags="All"
            BackgroundColor="#1e3a1e"
            IsVisible="{Binding IsSetupVisible}"
            Stroke="#6CB06C"
            StrokeShape="RoundRectangle 28"
            StrokeThickness="3">
            <Border.Shadow>
                <Shadow
                    Brush="Black"
                    Opacity="0.7"
                    Radius="20"
                    Offset="0,5" />
            </Border.Shadow>

            <!--  Behavior для анимации  -->
            <Border.Behaviors>
                <behavior:SlideUpBehavior BindingContext="{Binding Source={x:Reference Name=SetupPanel}, Path=BindingContext}" IsOpen="{Binding IsSetupVisible}" />
            </Border.Behaviors>

            <VerticalStackLayout Spacing="10">

                <!--  Заголовок + закрыть  -->
                <Grid ColumnDefinitions="*, Auto">
                    <Label
                        FontAttributes="Bold"
                        FontSize="20"
                        Text="Настройки раунда"
                        TextColor="#8CBB60"
                        VerticalOptions="Center" />
                    <Button
                        Grid.Column="1"
                        BackgroundColor="Transparent"
                        Command="{Binding CloseSetupCommand}"
                        FontSize="24"
                        Text="✕"
                        TextColor="#8CBB60" />
                </Grid>

                <!--  Создать поле  -->
                <Border
                    Grid.Column="0"
                    Stroke="#8CBB60"
                    StrokeShape="RoundRectangle 28"
                    StrokeThickness="2">
                    <Border.Shadow>
                        <Shadow
                            Brush="Black"
                            Opacity="0.5"
                            Radius="10"
                            Offset="0,2" />
                    </Border.Shadow>
                    <Border
                        Stroke="#477447"
                        StrokeShape="RoundRectangle 28"
                        StrokeThickness="3">
                        <Button
                            BackgroundColor="#6CB06C"
                            Command="{Binding GenerateFieldCommand}"
                            CornerRadius="28"
                            FontSize="18"
                            IsEnabled="{Binding SettingsAreValid}"
                            Text="Создать поле">
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroupList>
                                    <VisualStateGroup x:Name="CommonStates">
                                        <VisualState x:Name="Disabled">
                                            <VisualState.Setters>
                                                <Setter Property="BackgroundColor" Value="#718270" />
                                                <Setter Property="TextColor" Value="DarkRed" />
                                            </VisualState.Setters>
                                        </VisualState>
                                        <VisualState x:Name="Normal">
                                            <VisualState.Setters>
                                                <Setter Property="BackgroundColor" Value="#6CB06C" />
                                                <Setter Property="TextColor" Value="Black" />
                                            </VisualState.Setters>
                                        </VisualState>
                                    </VisualStateGroup>
                                </VisualStateGroupList>
                            </VisualStateManager.VisualStateGroups>
                        </Button>
                    </Border>
                </Border>

                <!--  Предпочтения  -->
                <Label
                    Margin="0,-4,0,0"
                    FontSize="12"
                    HorizontalOptions="Center"
                    Text="- Предпочтения -"
                    TextColor="#8CBB60" />

                <Grid ColumnDefinitions="*, *, *" ColumnSpacing="5">
                    <Border
                        Grid.Column="0"
                        Stroke="#8CBB60"
                        StrokeShape="RoundRectangle 28"
                        StrokeThickness="2">
                        <Border.Shadow>
                            <Shadow
                                Brush="Black"
                                Opacity="0.5"
                                Radius="10"
                                Offset="0,2" />
                        </Border.Shadow>
                        <Button
                            BackgroundColor="#6CB06C"
                            BorderColor="#477447"
                            BorderWidth="2"
                            Command="{Binding SavePreferencesCommand}"
                            CornerRadius="28"
                            IsEnabled="{Binding SettingsAreValid}"
                            LineBreakMode="WordWrap"
                            Text="💾" />
                    </Border>
                    <Border
                        Grid.Column="1"
                        Stroke="#8CBB60"
                        StrokeShape="RoundRectangle 28"
                        StrokeThickness="2">
                        <Border.Shadow>
                            <Shadow
                                Brush="Black"
                                Opacity="0.5"
                                Radius="10"
                                Offset="0,2" />
                        </Border.Shadow>
                        <Button
                            BackgroundColor="#6CB06C"
                            BorderColor="#477447"
                            BorderWidth="2"
                            Command="{Binding LoadPreferencesCommand}"
                            CornerRadius="28"
                            LineBreakMode="WordWrap"
                            Text="📤" />
                    </Border>
                    <Border
                        Grid.Column="2"
                        Stroke="#8CBB60"
                        StrokeShape="RoundRectangle 28"
                        StrokeThickness="2">
                        <Border.Shadow>
                            <Shadow
                                Brush="Black"
                                Opacity="0.5"
                                Radius="10"
                                Offset="0,2" />
                        </Border.Shadow>
                        <Button
                            BackgroundColor="#6CB06C"
                            BorderColor="#477447"
                            BorderWidth="2"
                            Command="{Binding ResetPreferencesCommand}"
                            CornerRadius="28"
                            LineBreakMode="WordWrap"
                            Text="🔄" />
                    </Border>
                </Grid>

                <!--  Сетка настроек (твой оригинальный стиль)  -->
                <ScrollView MaximumHeightRequest="400">
                    <Grid
                        Margin="3"
                        ColumnDefinitions="*, *, *, *"
                        ColumnSpacing="20"
                        RowDefinitions="*, *, *, *"
                        RowSpacing="5">

                        <!--  Высота  -->
                        <Border
                            Grid.Row="0"
                            Grid.Column="0"
                            Grid.ColumnSpan="2"
                            Stroke="#8CBB60"
                            StrokeShape="RoundRectangle 28"
                            StrokeThickness="1.5">
                            <Border.Shadow>
                                <Shadow
                                    Brush="Black"
                                    Opacity="0.5"
                                    Radius="10"
                                    Offset="0,2" />
                            </Border.Shadow>
                            <Grid
                                BackgroundColor="#305036"
                                ColumnDefinitions="3*, 2*"
                                ColumnSpacing="10"
                                HorizontalOptions="Fill">
                                <Label
                                    Grid.Column="0"
                                    HorizontalOptions="End"
                                    HorizontalTextAlignment="Center"
                                    Text="Высота"
                                    TextColor="#8CBB60"
                                    VerticalTextAlignment="Center" />
                                <Border
                                    Grid.Column="1"
                                    BackgroundColor="#477447"
                                    Stroke="Transparent"
                                    StrokeShape="RoundRectangle 20"
                                    VerticalOptions="Center">
                                    <Entry
                                        HorizontalTextAlignment="Center"
                                        Keyboard="Numeric"
                                        Placeholder="Rows"
                                        Text="{Binding Settings.Rows}" />
                                </Border>
                            </Grid>
                        </Border>

                        <!--  Ширина  -->
                        <Border
                            Grid.Row="0"
                            Grid.Column="2"
                            Grid.ColumnSpan="2"
                            BackgroundColor="#305036"
                            Stroke="#8CBB60"
                            StrokeShape="RoundRectangle 28"
                            StrokeThickness="1.5">
                            <Border.Shadow>
                                <Shadow
                                    Brush="Black"
                                    Opacity="0.5"
                                    Radius="10"
                                    Offset="0,2" />
                            </Border.Shadow>
                            <Grid
                                ColumnDefinitions="3*, 2*"
                                ColumnSpacing="10"
                                HorizontalOptions="Fill">
                                <Label
                                    Grid.Column="0"
                                    HorizontalOptions="End"
                                    HorizontalTextAlignment="Center"
                                    Text="Ширина"
                                    TextColor="#8CBB60"
                                    VerticalTextAlignment="Center" />
                                <Border
                                    Grid.Column="1"
                                    BackgroundColor="#477447"
                                    Stroke="Transparent"
                                    StrokeShape="RoundRectangle 20"
                                    VerticalOptions="Center">
                                    <Entry
                                        Grid.Row="0"
                                        HorizontalTextAlignment="Center"
                                        Keyboard="Numeric"
                                        Placeholder="Cols"
                                        Text="{Binding Settings.Cols}" />
                                </Border>
                            </Grid>
                        </Border>

                        <!--  Спавн (высота)  -->
                        <Border
                            Grid.Row="1"
                            Grid.Column="0"
                            Grid.ColumnSpan="2"
                            BackgroundColor="#305036"
                            Stroke="#8CBB60"
                            StrokeShape="RoundRectangle 28"
                            StrokeThickness="1.5">
                            <Border.Shadow>
                                <Shadow
                                    Brush="Black"
                                    Opacity="0.5"
                                    Radius="10"
                                    Offset="0,2" />
                            </Border.Shadow>
                            <Grid
                                ColumnDefinitions="3*, 2*"
                                ColumnSpacing="10"
                                HorizontalOptions="Fill">
                                <Label
                                    Grid.Column="0"
                                    HorizontalOptions="End"
                                    HorizontalTextAlignment="Center"
                                    LineBreakMode="WordWrap"
                                    Text="Спавн (высота)"
                                    TextColor="#8CBB60"
                                    VerticalTextAlignment="Center" />
                                <Border
                                    Grid.Column="1"
                                    BackgroundColor="#477447"
                                    Stroke="Transparent"
                                    StrokeShape="RoundRectangle 20"
                                    VerticalOptions="Center">
                                    <Entry
                                        Grid.Row="0"
                                        HorizontalTextAlignment="Center"
                                        Keyboard="Numeric"
                                        Placeholder="Snake spawn i"
                                        Text="{Binding Settings.SnakeSpawnPointI}" />
                                </Border>
                            </Grid>
                        </Border>

                        <!--  Спавн (ширина)  -->
                        <Border
                            Grid.Row="1"
                            Grid.Column="2"
                            Grid.ColumnSpan="2"
                            BackgroundColor="#305036"
                            Stroke="#8CBB60"
                            StrokeShape="RoundRectangle 28"
                            StrokeThickness="1.5">
                            <Border.Shadow>
                                <Shadow
                                    Brush="Black"
                                    Opacity="0.5"
                                    Radius="10"
                                    Offset="0,2" />
                            </Border.Shadow>
                            <Grid
                                ColumnDefinitions="3*, 2*"
                                ColumnSpacing="10"
                                HorizontalOptions="Fill">
                                <Label
                                    Grid.Column="0"
                                    HorizontalOptions="End"
                                    HorizontalTextAlignment="Center"
                                    LineBreakMode="WordWrap"
                                    Text="Спавн (ширина)"
                                    TextColor="#8CBB60"
                                    VerticalTextAlignment="Center" />
                                <Border
                                    Grid.Column="1"
                                    BackgroundColor="#477447"
                                    Stroke="Transparent"
                                    StrokeShape="RoundRectangle 20"
                                    VerticalOptions="Center">
                                    <Entry
                                        Grid.Row="0"
                                        HorizontalTextAlignment="Center"
                                        Keyboard="Numeric"
                                        Placeholder="Snake spawn j"
                                        Text="{Binding Settings.SnakeSpawnPointJ}" />
                                </Border>
                            </Grid>
                        </Border>

                        <!--  Кол-во бомб  -->
                        <Border
                            Grid.Row="2"
                            Grid.Column="0"
                            Grid.ColumnSpan="2"
                            BackgroundColor="#305036"
                            Stroke="#8CBB60"
                            StrokeShape="RoundRectangle 28"
                            StrokeThickness="1.5">
                            <Border.Shadow>
                                <Shadow
                                    Brush="Black"
                                    Opacity="0.5"
                                    Radius="10"
                                    Offset="0,2" />
                            </Border.Shadow>
                            <Grid
                                ColumnDefinitions="3*, 2*"
                                ColumnSpacing="10"
                                HorizontalOptions="Fill">
                                <Label
                                    Grid.Column="0"
                                    HorizontalOptions="End"
                                    HorizontalTextAlignment="Center"
                                    Text="Кол-во бомб"
                                    TextColor="#8CBB60"
                                    VerticalTextAlignment="Center" />
                                <Border
                                    Grid.Column="1"
                                    BackgroundColor="#477447"
                                    HorizontalOptions="Fill"
                                    Stroke="Transparent"
                                    StrokeShape="RoundRectangle 20"
                                    VerticalOptions="Fill">
                                    <Entry
                                        Grid.Row="0"
                                        HorizontalTextAlignment="Center"
                                        Keyboard="Numeric"
                                        Placeholder="Bombs count"
                                        Text="{Binding Settings.BombsCount}"
                                        VerticalOptions="Center" />
                                </Border>
                            </Grid>
                        </Border>

                        <!--  Зерно  -->
                        <Border
                            Grid.Row="2"
                            Grid.Column="2"
                            Grid.ColumnSpan="2"
                            BackgroundColor="#305036"
                            Stroke="#8CBB60"
                            StrokeShape="RoundRectangle 28"
                            StrokeThickness="1.5">
                            <Border.Shadow>
                                <Shadow
                                    Brush="Black"
                                    Opacity="0.5"
                                    Radius="10"
                                    Offset="0,2" />
                            </Border.Shadow>
                            <Grid
                                ColumnDefinitions="3*, 2*"
                                ColumnSpacing="10"
                                HorizontalOptions="Fill">
                                <Label
                                    Grid.Column="0"
                                    HorizontalOptions="End"
                                    HorizontalTextAlignment="Center"
                                    Text="Зерно"
                                    TextColor="#8CBB60"
                                    VerticalTextAlignment="Center" />
                                <Border
                                    Grid.Column="1"
                                    BackgroundColor="#477447"
                                    Stroke="Transparent"
                                    StrokeShape="RoundRectangle 20"
                                    VerticalOptions="Fill">
                                    <Entry
                                        Grid.Row="0"
                                        HorizontalTextAlignment="Center"
                                        Keyboard="Numeric"
                                        Placeholder="Зерно (число)"
                                        Text="{Binding Settings.Seed}"
                                        VerticalOptions="Center" />
                                </Border>
                            </Grid>
                        </Border>

                        <!--  Скорость  -->
                        <Label
                            Grid.Row="3"
                            Grid.Column="0"
                            Grid.ColumnSpan="2"
                            FontSize="18"
                            HorizontalTextAlignment="Center"
                            Text="{Binding Settings.SpeedFactor, StringFormat='Скорость игры: {0:F1}'}"
                            TextColor="#8CBB60"
                            VerticalTextAlignment="Center" />
                        <Grid
                            Grid.Row="3"
                            Grid.Column="2"
                            Grid.ColumnSpan="2"
                            ColumnDefinitions="*, *"
                            ColumnSpacing="10">
                            <Button
                                Grid.Column="0"
                                BackgroundColor="#477447"
                                BorderColor="#8CBB60"
                                BorderWidth="1.5"
                                Command="{Binding DecrementStepSpeedCommand}"
                                CornerRadius="100"
                                FontAttributes="Bold"
                                FontSize="26"
                                Text="−"
                                TextColor="#8CBB60">
                                <Button.Shadow>
                                    <Shadow
                                        Brush="Black"
                                        Opacity="0.5"
                                        Radius="10"
                                        Offset="0,2" />
                                </Button.Shadow>
                            </Button>
                            <Button
                                Grid.Column="1"
                                BackgroundColor="#477447"
                                BorderColor="#8CBB60"
                                BorderWidth="1.5"
                                Command="{Binding IncrementStepSpeedCommand}"
                                CornerRadius="100"
                                FontAttributes="Bold"
                                FontAutoScalingEnabled="True"
                                FontSize="26"
                                Text="+"
                                TextColor="#8CBB60">
                                <Button.Shadow>
                                    <Shadow
                                        Brush="Black"
                                        Opacity="0.5"
                                        Radius="10"
                                        Offset="0,2" />
                                </Button.Shadow>
                            </Button>
                        </Grid>

                    </Grid>
                </ScrollView>

            </VerticalStackLayout>
        </Border>

    </AbsoluteLayout>
</ContentPage>