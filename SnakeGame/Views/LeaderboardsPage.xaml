<?xml version="1.0" encoding="utf-8"?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    
    xmlns:vm="clr-namespace:SnakeGame"
    
    xmlns:c="clr-namespace:SnakeGame.Custom"
    
    xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
    x:Class="SnakeGame.LeaderboardsPage"
    Title="🏆 Рекорды"
    Shell.NavBarIsVisible="False"
    BackgroundColor="#121212">
    <ContentPage.Resources>
        <ResourceDictionary>
            <!-- Конвертеры -->
            <c:DifficultyToColorConverter
                x:Key="DifficultyColor" />
            <c:DifficultyToBackgroundConverter
                x:Key="DifficultyBg" />
            <c:DeathReasonToMessageConverter
                x:Key="DeathReason" />
            <c:IndexToRankConverter
                x:Key="RankConv" />
            <c:DateTimeToShortStringConverter
                x:Key="DateFmt" />
            <c:ScoreToFormattedStringConverter
                x:Key="ScoreFmt" />
            <!-- Триггер анимации появления -->
            <toolkit:AnimationBehavior
                x:Key="FadeInBehavior">
                <toolkit:AnimationBehavior.AnimationType>
                    <toolkit:FadeAnimation />
                </toolkit:AnimationBehavior.AnimationType>
            </toolkit:AnimationBehavior>
        </ResourceDictionary>
    </ContentPage.Resources>
    <Grid
        Padding="12,8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <VerticalStackLayout
            Grid.Row="1"
            Spacing="15">
            <Button
                Text="В главное меню"
                HorizontalOptions="Fill"
                BackgroundColor="LightGreen"
                Command="{Binding GoBackCommand}" />
            <Label
                Text="🏆 Рекорды 🏆"
                FontSize="20"
                HorizontalTextAlignment="Center" />
            <Label
                Text="{Binding Records.Count, StringFormat='{0} записей'}"
                HorizontalTextAlignment="Center"
                Padding="0, -6, 0, 10"
                FontSize="16"
                TextColor="#888888" />

        </VerticalStackLayout>
        
        <!-- Список -->
        <RefreshView
            Grid.Row="2"
            IsRefreshing="{Binding IsRefreshing}"
            Command="{Binding LoadRecordsCommand}">
            <CollectionView
                ItemsSource="{Binding Records}"
                SelectionMode="Single"
                SelectedItem="{Binding SelectedRecord}"
                SelectionChangedCommand="{Binding ItemTappedCommand}"
                RemainingItemsThreshold="5"
                RemainingItemsThresholdReachedCommand="{Binding LoadMoreCommand}">
                <CollectionView.ItemsLayout>
                    <LinearItemsLayout
                        Orientation="Vertical"
                        ItemSpacing="8" />
                </CollectionView.ItemsLayout>
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border
                            BackgroundColor="#1E1E1E"
                            Stroke="#2A2A2A"
                            StrokeShape="RoundRectangle 16"
                            StrokeThickness="1"
                            Padding="16,14"
                            Margin="0, 4">
                            <VerticalStackLayout
                                Spacing="0">
                                <!-- Верхняя строка: ранг + имя -->
                                <Grid
                                    ColumnDefinitions="Auto, *"
                                    ColumnSpacing="6">
                                    <Frame
                                        Grid.Column="0"
                                        BackgroundColor="{Binding DifficultyLevel, Converter={StaticResource DifficultyBg}}"
                                        CornerRadius="20"
                                        Padding="0"
                                        WidthRequest="40"
                                        HeightRequest="40">
                                        <Label
                                            Text="{Binding Rank}"
                                            FontSize="16"
                                            FontAttributes="Bold"
                                            HorizontalOptions="Center"
                                            VerticalOptions="Center" />
                                    </Frame>
                                    <VerticalStackLayout
                                        Grid.Column="1"
                                        Spacing="2">
                                        <Label
                                            Text="{Binding PlayerName}"
                                            FontSize="16"
                                            FontAttributes="Bold"
                                            TextColor="#FFF" />
                                        <Label
                                            Text="{Binding DtSnapshot, Converter={StaticResource DateFmt}}"
                                            FontSize="12"
                                            TextColor="#888" />
                                    </VerticalStackLayout>
                                </Grid>
                                <!-- Разделитель -->
                                <BoxView
                                    HeightRequest="1"
                                    BackgroundColor="#333"
                                    Margin="0,10" />
                                <!-- Средняя зона: очки и длина -->
                                <Grid
                                    ColumnDefinitions="*,*,*"
                                    Margin="0,0,0,10">
                                    <VerticalStackLayout
                                        Grid.Column="0"
                                        HorizontalOptions="Center">
                                        <Label
                                            Text="ОЧКИ"
                                            HorizontalTextAlignment="Center"
                                            FontSize="10"
                                            TextColor="#666" />
                                        <Label
                                            Text="{Binding Score, Converter={StaticResource ScoreFmt}}"
                                            FontSize="22"
                                            HorizontalTextAlignment="Center"
                                            FontAttributes="Bold"
                                            TextColor="#4EC9B0" />
                                    </VerticalStackLayout>
                                    <VerticalStackLayout
                                        Grid.Column="1"
                                        HorizontalOptions="Center">
                                        <Label
                                            Text="ДЛИНА"
                                            HorizontalTextAlignment="Center"
                                            FontSize="10"
                                            TextColor="#666" />
                                        <Label
                                            Text="{Binding MaxSnakeLength, StringFormat='{0}'}"
                                            FontSize="22"
                                            HorizontalTextAlignment="Center"
                                            FontAttributes="Bold"
                                            TextColor="#CE9178" />
                                    </VerticalStackLayout>
                                    <VerticalStackLayout
                                        Grid.Column="2"
                                        HorizontalOptions="Center">
                                        <Label
                                            Text="СЛОЖНОСТЬ"
                                            HorizontalTextAlignment="Center"
                                            FontSize="10"
                                            TextColor="#666" />
                                        <Label
                                            Text="{Binding DifficultyLevel}"
                                            FontSize="22"
                                            HorizontalTextAlignment="Center"
                                            FontAttributes="Bold"
                                            TextColor="{Binding DifficultyLevel, Converter={StaticResource DifficultyBg}}" />
                                    </VerticalStackLayout>
                                </Grid>
                                <!-- Низ: бейдж сложности + причина смерти -->
                                <Grid
                                    ColumnDefinitions="Auto,*"
                                    ColumnSpacing="8">
                                    <Label
                                        Grid.Column="1"
                                        Text="{Binding DeathReason, Converter={StaticResource DeathReason}}"
                                        FontSize="13"
                                        TextColor="#9CDCFE"
                                        HorizontalOptions="Center"
                                        VerticalOptions="Center"
                                        LineBreakMode="TailTruncation" />
                                </Grid>
                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
                <!-- Пустое состояние -->
                <CollectionView.EmptyView>
                    <Grid
                        VerticalOptions="Center"
                        HorizontalOptions="Center">
                        <VerticalStackLayout
                            Spacing="16"
                            HorizontalOptions="Center">
                            <Label
                                Text="🐍"
                                FontSize="72"
                                HorizontalOptions="Center" />
                            <Label
                                Text="Пока нет рекордов"
                                FontSize="20"
                                TextColor="#888"
                                HorizontalOptions="Center" />
                            <Label
                                Text="Сыграй первую игру, чтобы попасть в таблицу!"
                                FontSize="14"
                                TextColor="#555"
                                HorizontalTextAlignment="Center"
                                HorizontalOptions="Center" />
                        </VerticalStackLayout>
                    </Grid>
                </CollectionView.EmptyView>
            </CollectionView>
        </RefreshView>
    </Grid>
</ContentPage>