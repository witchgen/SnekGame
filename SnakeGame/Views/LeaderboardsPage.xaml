<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="SnakeGame.LeaderboardsPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:c="clr-namespace:SnakeGame.Custom"
    xmlns:playdata="clr-namespace:SnakeGame.Models.LegacyGame.GameInfo"
    xmlns:playinfo="clr-namespace:SnakeGame.SnekEngine.Abstractions.Models"
    xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
    xmlns:vm="clr-namespace:SnakeGame.ViewModels"
    Title="🏆 Рекорды"
    x:DataType="vm:LeaderboardViewModel"
    BackgroundColor="#121212"
    Shell.NavBarIsVisible="False">
    <ContentPage.Resources>
        <ResourceDictionary>
            <!--  Конвертеры  -->
            <c:DifficultyToColorConverter x:Key="DifficultyColor" />
            <c:LegacyDifficultyToBackgroundConverter x:Key="DifficultyBgLegacy" />
            <c:DeathReasonToMessageConverter x:Key="DeathReasonLegacy" />
            <c:IndexToRankConverter x:Key="RankConv" />
            <c:DateTimeToShortStringConverter x:Key="DateFmt" />
            <c:ScoreToFormattedStringConverter x:Key="ScoreFmt" />
            <c:BoolToColorConverter
                x:Key="BoolToColor"
                FalseColor="#718270"
                TrueColor="#84C248" />
            <c:GameOverReasonToMessageConverter x:Key="NewGameOver" />
            <c:RankToColorConverter x:Key="RankColorFmt" />
            <c:RankToBrushConverter x:Key="BrushFmt" />
            <!--  Триггер анимации появления  -->
            <toolkit:AnimationBehavior x:Key="FadeInBehavior">
                <toolkit:AnimationBehavior.AnimationType>
                    <toolkit:FadeAnimation />
                </toolkit:AnimationBehavior.AnimationType>
            </toolkit:AnimationBehavior>
        </ResourceDictionary>
    </ContentPage.Resources>
    <Grid Padding="12,8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <VerticalStackLayout Grid.Row="0" Spacing="15">
            <Button
                BackgroundColor="#84a98c"
                Command="{Binding GoBackCommand}"
                HorizontalOptions="Fill"
                Text="В главное меню" />
            <Label
                FontSize="20"
                HorizontalTextAlignment="Center"
                Text="🏆 Рекорды 🏆" />
            <!--<Label
                Text="{Binding LegacyRecords.Count, StringFormat='{0} записей'}"
                HorizontalTextAlignment="Center"
                Padding="0, -6, 0, 10"
                FontSize="16"
                TextColor="#888888" />-->

        </VerticalStackLayout>

        <!--  Табы  -->
        <Grid
            Grid.Row="1"
            Margin="0,0,0,12"
            Padding="10"
            ColumnDefinitions="*,*"
            IsVisible="{Binding HasLegacyRecords}">

            <Button
                Grid.Column="0"
                BackgroundColor="{Binding IsNewTabSelected, Converter={StaticResource BoolToColor}}"
                Command="{Binding SelectNewTabCommand}"
                Text="Новые"
                TextColor="Black" />

            <Button
                Grid.Column="1"
                BackgroundColor="{Binding IsLegacyTabSelected, Converter={StaticResource BoolToColor}}"
                Command="{Binding SelectLegacyTabCommand}"
                IsVisible="{Binding HasLegacyRecords}"
                Text="Legacy"
                TextColor="Black" />
        </Grid>

        <!--  Новые рекорды  -->
        <Label
            Grid.Row="2"
            Padding="0,-6,0,10"
            FontSize="16"
            HorizontalTextAlignment="Center"
            IsVisible="{Binding IsNewTabSelected}"
            Text="{Binding NewRecords.Count, StringFormat='{0} записей'}"
            TextColor="#888888" />
        <RefreshView
            Grid.Row="3"
            Command="{Binding LoadNewRecordsCommand}"
            IsRefreshing="{Binding IsRefreshingNew}"
            IsVisible="{Binding IsNewTabSelected}">
            <CollectionView
                ItemsSource="{Binding NewRecords}"
                SelectedItem="{Binding SelectedRecord}"
                SelectionChangedCommand="{Binding ItemTappedCommand}"
                SelectionMode="Single">
                <CollectionView.ItemsLayout>
                    <LinearItemsLayout ItemSpacing="8" Orientation="Vertical" />
                </CollectionView.ItemsLayout>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="playinfo:PlayInfo">
                        <Border
                            Margin="0,4"
                            Padding="16,14"
                            BackgroundColor="#1E1E1E"
                            Stroke="{Binding Rank, Converter={StaticResource BrushFmt}}"
                            StrokeShape="RoundRectangle 16"
                            StrokeThickness="1">
                            <VerticalStackLayout Spacing="0">
                                <!--  Верхняя строка: ранг + имя  -->
                                <Grid ColumnDefinitions="Auto, *" ColumnSpacing="6">
                                    <Border
                                        Grid.Column="0"
                                        Padding="0"
                                        BackgroundColor="{Binding Rank, Converter={StaticResource RankColorFmt}}"
                                        HeightRequest="40"
                                        StrokeShape="RoundRectangle 20"
                                        WidthRequest="40">
                                        <Label
                                            FontAttributes="Bold"
                                            FontSize="16"
                                            HorizontalOptions="Center"
                                            Text="{Binding Rank}"
                                            TextColor="Black"
                                            VerticalOptions="Center" />
                                    </Border>
                                    <VerticalStackLayout Grid.Column="1" Spacing="2">
                                        <Label
                                            FontAttributes="Bold"
                                            FontSize="16"
                                            Text="{Binding PlayerName}"
                                            TextColor="#FFF" />
                                        <Label
                                            FontSize="12"
                                            Text="{Binding DtEnded, Converter={StaticResource DateFmt}}"
                                            TextColor="#888" />
                                    </VerticalStackLayout>
                                </Grid>
                                <!--  Разделитель  -->
                                <BoxView
                                    Margin="0,10"
                                    BackgroundColor="#333"
                                    HeightRequest="1" />
                                <!--  Средняя зона: очки и длина  -->
                                <Grid Margin="0,0,0,10" ColumnDefinitions="*,*,*">
                                    <VerticalStackLayout Grid.Column="0" HorizontalOptions="Center">
                                        <Label
                                            FontSize="10"
                                            HorizontalTextAlignment="Center"
                                            Text="ОЧКИ"
                                            TextColor="#666" />
                                        <Label
                                            FontAttributes="Bold"
                                            FontSize="22"
                                            HorizontalTextAlignment="Center"
                                            Text="{Binding FinalScore, Converter={StaticResource ScoreFmt}}"
                                            TextColor="#4EC9B0" />
                                    </VerticalStackLayout>
                                    <VerticalStackLayout Grid.Column="1" HorizontalOptions="Center">
                                        <Label
                                            FontSize="10"
                                            HorizontalTextAlignment="Center"
                                            Text="ДЛИНА"
                                            TextColor="#666" />
                                        <Label
                                            FontAttributes="Bold"
                                            FontSize="22"
                                            HorizontalTextAlignment="Center"
                                            Text="{Binding MaxSnakeLength, StringFormat='{0}'}"
                                            TextColor="#CE9178" />
                                    </VerticalStackLayout>

                                </Grid>
                                <!--  Низ: бейдж сложности + причина смерти  -->
                                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                                    <Label
                                        Grid.Column="1"
                                        FontSize="13"
                                        HorizontalOptions="Center"
                                        LineBreakMode="TailTruncation"
                                        Text="{Binding DeathReason, Converter={StaticResource NewGameOver}}"
                                        TextColor="#9CDCFE"
                                        VerticalOptions="Center" />
                                </Grid>
                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
                <!--  Пустое состояние  -->
                <CollectionView.EmptyView>
                    <Grid HorizontalOptions="Center" VerticalOptions="Center">
                        <VerticalStackLayout HorizontalOptions="Center" Spacing="16">
                            <Label
                                FontSize="72"
                                HorizontalOptions="Center"
                                Text="🐍" />
                            <Label
                                FontSize="20"
                                HorizontalOptions="Center"
                                Text="Пока нет рекордов"
                                TextColor="#888" />
                            <Label
                                FontSize="14"
                                HorizontalOptions="Center"
                                HorizontalTextAlignment="Center"
                                Text="Сыграй первую игру, чтобы попасть в таблицу!"
                                TextColor="#555" />
                        </VerticalStackLayout>
                    </Grid>
                </CollectionView.EmptyView>
            </CollectionView>
        </RefreshView>

        <!--  Легаси список  -->
        <Label
            Grid.Row="2"
            Padding="0,-6,0,10"
            FontSize="16"
            HorizontalTextAlignment="Center"
            IsVisible="{Binding IsLegacyTabSelected}"
            Text="{Binding LegacyRecords.Count, StringFormat='{0} записей'}"
            TextColor="#888888" />
        <RefreshView
            Grid.Row="3"
            Command="{Binding LoadLegacyRecordsCommand}"
            IsRefreshing="{Binding IsRefreshingLegacy}"
            IsVisible="{Binding IsLegacyTabSelected}">
            <CollectionView ItemsSource="{Binding LegacyRecords}" SelectionMode="Single">
                <CollectionView.ItemsLayout>
                    <LinearItemsLayout ItemSpacing="8" Orientation="Vertical" />
                </CollectionView.ItemsLayout>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="playdata:PlayData">
                        <Border
                            Margin="0,4"
                            Padding="16,14"
                            BackgroundColor="#1E1E1E"
                            Stroke="#2A2A2A"
                            StrokeShape="RoundRectangle 16"
                            StrokeThickness="1">
                            <VerticalStackLayout Spacing="0">
                                <!--  Верхняя строка: ранг + имя  -->
                                <Grid ColumnDefinitions="Auto, *" ColumnSpacing="6">
                                    <Border
                                        Grid.Column="0"
                                        Padding="0"
                                        BackgroundColor="{Binding DifficultyLevel, Converter={StaticResource DifficultyBgLegacy}}"
                                        HeightRequest="40"
                                        StrokeShape="RoundRectangle 20"
                                        WidthRequest="40">
                                        <Label
                                            FontAttributes="Bold"
                                            FontSize="16"
                                            HorizontalOptions="Center"
                                            Text="{Binding Rank}"
                                            VerticalOptions="Center" />
                                    </Border>
                                    <VerticalStackLayout Grid.Column="1" Spacing="2">
                                        <Label
                                            FontAttributes="Bold"
                                            FontSize="16"
                                            Text="{Binding PlayerName}"
                                            TextColor="#FFF" />
                                        <Label
                                            FontSize="12"
                                            Text="{Binding DtSnapshot, Converter={StaticResource DateFmt}}"
                                            TextColor="#888" />
                                    </VerticalStackLayout>
                                </Grid>
                                <!--  Разделитель  -->
                                <BoxView
                                    Margin="0,10"
                                    BackgroundColor="#333"
                                    HeightRequest="1" />
                                <!--  Средняя зона: очки и длина  -->
                                <Grid Margin="0,0,0,10" ColumnDefinitions="*,*,*">
                                    <VerticalStackLayout Grid.Column="0" HorizontalOptions="Center">
                                        <Label
                                            FontSize="10"
                                            HorizontalTextAlignment="Center"
                                            Text="ОЧКИ"
                                            TextColor="#666" />
                                        <Label
                                            FontAttributes="Bold"
                                            FontSize="22"
                                            HorizontalTextAlignment="Center"
                                            Text="{Binding Score, Converter={StaticResource ScoreFmt}}"
                                            TextColor="#4EC9B0" />
                                    </VerticalStackLayout>
                                    <VerticalStackLayout Grid.Column="1" HorizontalOptions="Center">
                                        <Label
                                            FontSize="10"
                                            HorizontalTextAlignment="Center"
                                            Text="ДЛИНА"
                                            TextColor="#666" />
                                        <Label
                                            FontAttributes="Bold"
                                            FontSize="22"
                                            HorizontalTextAlignment="Center"
                                            Text="{Binding MaxSnakeLength, StringFormat='{0}'}"
                                            TextColor="#CE9178" />
                                    </VerticalStackLayout>
                                    <VerticalStackLayout Grid.Column="2" HorizontalOptions="Center">
                                        <Label
                                            FontSize="10"
                                            HorizontalTextAlignment="Center"
                                            Text="СЛОЖНОСТЬ"
                                            TextColor="#666" />
                                        <Label
                                            FontAttributes="Bold"
                                            FontSize="22"
                                            HorizontalTextAlignment="Center"
                                            Text="{Binding DifficultyLevel}"
                                            TextColor="{Binding DifficultyLevel, Converter={StaticResource DifficultyBgLegacy}}" />
                                    </VerticalStackLayout>
                                </Grid>
                                <!--  Низ: бейдж сложности + причина смерти  -->
                                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                                    <Label
                                        Grid.Column="1"
                                        FontSize="13"
                                        HorizontalOptions="Center"
                                        LineBreakMode="TailTruncation"
                                        Text="{Binding DeathReason, Converter={StaticResource DeathReasonLegacy}}"
                                        TextColor="#9CDCFE"
                                        VerticalOptions="Center" />
                                </Grid>
                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
                <!--  Пустое состояние  -->
                <!--<CollectionView.EmptyView>
                    <Grid HorizontalOptions="Center" VerticalOptions="Center">
                        <VerticalStackLayout HorizontalOptions="Center" Spacing="16">
                            <Label
                                FontSize="72"
                                HorizontalOptions="Center"
                                Text="🐍" />
                            <Label
                                FontSize="20"
                                HorizontalOptions="Center"
                                Text="Пока нет рекордов"
                                TextColor="#888" />
                            <Label
                                FontSize="14"
                                HorizontalOptions="Center"
                                HorizontalTextAlignment="Center"
                                Text="Сыграй первую игру, чтобы попасть в таблицу!"
                                TextColor="#555" />
                        </VerticalStackLayout>
                    </Grid>
                </CollectionView.EmptyView>-->
            </CollectionView>
        </RefreshView>
    </Grid>
</ContentPage>