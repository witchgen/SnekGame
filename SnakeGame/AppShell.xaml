<?xml version="1.0" encoding="utf-8"?>
<Shell
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    
    xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
    
    xmlns:local="clr-namespace:SnakeGame"
    
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="SnakeGame.AppShell"
    Shell.FlyoutBehavior="Disabled">
    <ShellContent
        Route="MainMenu"
        Title="Змея подколодная"
        ContentTemplate="{DataTemplate local:MainMenu}" />
    <ShellContent
        Route="LegacyGamePage"
        Title="Змеюка Легаси"
        ContentTemplate="{DataTemplate local:LegacyGamePage}" />
    <ShellContent
        Title="Рекорды"
        Route="LeaderboardsPage"
        ContentTemplate="{DataTemplate local:LeaderboardsPage}" />
</Shell>